export AGENTICREC_REPO_ROOT=/path/to/agent_memcf_v2_repo
export AGENTICREC_DATA_ROOT=$AGENTICREC_REPO_ROOT/data
export AGENTICREC_MEMORY_ROOT=$AGENTICREC_REPO_ROOT/agent_memory
export AGENTICREC_EVAL_ROOT=$AGENTICREC_REPO_ROOT/evaluation_results

# OpenAI-compatible chat endpoint
export chat_api_base=http://127.0.0.1:8000/v1
export api_base=http://127.0.0.1:8000/v1
export chat_model_name=gpt-3.5-turbo-16k-0613

# SentenceTransformer local model or model id
export embedding_model_name=sentence-transformers/all-MiniLM-L6-v2
